generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(uuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  username        String   @unique
  password        String
  role            EnumRole @default(EXECUTOR)
  isActive        Boolean  @default(true)
  rateBasisPoints  Int?
  // Ставка премии за разработку дизайна (в сотых процента). Есть только у роли
  // ORDER_MANAGER: помимо базовой ставки, менеджер получает этот процент от
  // суммы «разработка дизайна» в заказе. 4000 = 40%.
  designRateBasisPoints Int?
  telegramUsername String?

  salaryAccruals     SalaryAccrual[]
  salaryPayments     SalaryPayment[]   @relation("SalaryPaymentExecutor")
  authorizedPayments SalaryPayment[]   @relation("SalaryPaymentAuthor")
  assignedOrders     OrderPhoto[]      @relation("OrderExecutor")
  processedOrders    OrderPhoto[]      @relation("OrderProcessedBy")
  rateHistory        UserRateHistory[]
  expenseOrders      ExpenseOrder[]
  assignedTasks      Task[]            @relation("TaskAssignee")
  authoredTasks      Task[]            @relation("TaskAuthor")
}

enum EnumRole {
  ADMIN
  EXECUTOR
  // Менеджер по оформлению заказов: те же права по заказам, что у админа, но
  // без доступа к «управляющим» разделам (склад, зарплата, отчёты, сотрудники,
  // настройки). Получает базовую ставку за оформленный заказ + премию за дизайн.
  ORDER_MANAGER
}

model OrderPhoto {
  id        String   @id() @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  numberOrder           String              @unique
  sourceOrder           EnumSourceOrder
  communicationPlatform EnumCommunication
  urlCommunication      String
  deliveryMethod        EnumDeliveryMethod
  deliveryCost          Int
  totalOrder            Int
  note                  String?
  status                EnumStatus          @default(NEW)
  productCategory       EnumProductCategory @default(PHOTO)
  deadline              DateTime?
  isUrgent              Boolean             @default(false)
  // Свободная (договорная) цена: сумма позиции = её цене, количество НЕ умножается.
  isFreePrice           Boolean             @default(false)
  // Оставил ли клиент отзыв (отмечается вручную в списке заказов).
  clientReviewLeft      Boolean             @default(false)
  // Когда CRM автоматически напомнила рабочей группе попросить отзыв у клиента.
  reviewReminderNotifiedAt DateTime?
  // Когда статус менялся в последний раз. По нему видно «зависшие» заказы:
  // updatedAt для этого не годится — он дёргается от любой правки заказа.
  statusChangedAt DateTime?

  // Стоимость «разработка дизайна» по заказу (свободная цена, без количества).
  // Входит в totalOrder (клиент платит за неё) и служит базой премии менеджера
  // по оформлению: см. designRateBasisPoints у пользователя и SalaryAccrual.kind.
  designDevelopmentCost Int @default(0)

  // Кто оформил заказ. Если это менеджер по оформлению (ORDER_MANAGER) — ему при
  // переходе в «Отправлен» начисляется зарплата (базовая ставка + премия дизайна).
  processedById String?
  processedBy   User?   @relation("OrderProcessedBy", fields: [processedById], references: [id])

  // Черновик оформления: какой сценарий ведёт менеджер и что он уже выяснил у
  // клиента. Живёт здесь, а не в браузере: переписка идёт часами, вкладку
  // закрывают, а собранное должно пережить это. После оформления заказа поля
  // остаются — по ним видно, что именно спрашивали.
  scenarioKey     String?
  scenarioAnswers Json?

  // Модель футболки — производственные данные, уходят исполнителю-партнёру.
  tshirtModel String?
  // Путь к загруженному ТЗ-фото (согласованный с клиентом макет) на диске сервера.
  techSpecPhotoPath String?

  // Отправка заказа исполнителю-партнёру (внешняя печать футболок).
  // externalRequestId — ключ идемпотентности запроса к партнёру.
  externalRequestId String?                @unique
  partnerSyncStatus EnumPartnerSyncStatus?
  partnerSyncError  String?
  partnerSyncAt     DateTime?

  executorId   String?
  executor     User?     @relation("OrderExecutor", fields: [executorId], references: [id])
  completedAt  DateTime?
  sentAt       DateTime?
  clientPaidAt DateTime?

  items          ItemPhoto[]
  tshirtItems    ItemTshirt[]
  accruals       SalaryAccrual[]
  statusHistory  StatusHistory[]
  assignments    OrderAssignment[]
  stockMovements StockMovement[]
  tasks          Task[]
  expenses       ExpenseOrder[]

  @@index([status])
  @@index([executorId])
  @@index([processedById])
  @@index([createdAt])
  @@index([productCategory])
  @@index([status, productCategory])
  @@index([productCategory, status, reviewReminderNotifiedAt])
}

/// Остаток футболок на складе по размеру и цвету (6 размеров × 2 цвета).
model TshirtStock {
  id        String         @id @default(uuid())
  size      EnumTshirtSize
  color     String
  quantity  Int            @default(0)
  updatedAt DateTime       @updatedAt

  @@unique([size, color])
}

/// Журнал списаний склада по заказу (положительное quantity = списано).
/// Возврат при откате из «Отправлен»/удалении возвращает ровно списанное.
model StockMovement {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  orderId String
  order   OrderPhoto @relation(fields: [orderId], references: [id], onDelete: Cascade)

  size     EnumTshirtSize
  color    String
  quantity Int

  @@index([orderId])
}

enum EnumProductCategory {
  PHOTO
  TSHIRT
}

/// Статус отправки заказа партнёру CoolABC.
enum EnumPartnerSyncStatus {
  PENDING
  SENT
  FAILED
}

enum EnumExpenseCategory {
  MATERIALS_PHOTO
  MATERIALS_TSHIRT
  DELIVERY_SUPPLIES
  EQUIPMENT
  MARKETING
  PARTNER_SHARE
  // Вознаграждение партнёру-исполнителю за печать футболок. Создаётся
  // автоматически, когда заказ переходит в «Оплачен».
  PARTNER_REWARD
  OTHER
}

enum EnumSourceOrder {
  AVITO
  OZON
  WB
  LOCAL
}

enum EnumCommunication {
  AVITO
  TELEGRAM
  MAX
  OZON
}

enum EnumStatus {
  LEAD
  NEW
  FOLDER_STRUCTURE_CREATED
  IN_PROGRESS
  PRINTED
  READY
  DONE
  SENT
  PAID
  READY_FOR_REVIEW
  COMPLETED
  CANCELLED
}

enum EnumDeliveryMethod {
  YANDEX_PVZ
  OZON_PVZ
  PICKUP
  OZON_SELLER
  WB_SELLER
}

model ItemPhoto {
  id        String   @id() @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   OrderPhoto @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  formatPaper   String
  typePaper     EnumTypePaper
  quantity      Int
  price         Int
  pricePosition Int
  // Позиция со свободной (договорной) ценой: pricePosition = price, кол-во не умножается.
  isFreePrice   Boolean @default(false)
}

enum EnumTypePaper {
  GLOSS
  MATTE
}

model ItemTshirt {
  id        String   @id() @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   OrderPhoto @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  color         String
  size          EnumTshirtSize
  gender        EnumTshirtGender  @default(UNISEX)
  printLocation EnumPrintLocation
  printType     EnumPrintType     @default(DTF)
  quantity      Int
  price         Int
  pricePosition Int
  designCost    Int               @default(0)
  // Себестоимость печати этой позиции — снимок на момент оформления, чтобы
  // расчёт с партнёром не «поехал», если позже поменять значения по умолчанию.
  // Термоперенос берётся всегда; стоимость футболки — только если она наша
  // (для давальческой clientItem=true заготовку покупает клиент).
  thermalCost   Int               @default(70)
  blankCost     Int               @default(260)
  designUrl     String?
  designNote    String?
  clientItem    Boolean           @default(false)
}

enum EnumTshirtSize {
  XS
  S
  M
  L
  XL
  XXL
  XXXL
}

enum EnumTshirtGender {
  UNISEX
  MALE
  FEMALE
  KIDS
}

enum EnumPrintLocation {
  FRONT
  BACK
  FRONT_BACK
  SLEEVE_LEFT
  SLEEVE_RIGHT
  FULL
  BY_TZ
}

enum EnumPrintType {
  DTF
  DTG
  SILK
  SUBLIMATION
}

enum EnumAccrualStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  SETTLED
  REVERSED
}

/// Кому и за что начисление.
///  - EXECUTOR: исполнителю за производство (база = чек − доставка).
///  - MANAGER:  менеджеру по оформлению. salaryAmount = базовая часть
///    (salaryBase × rateBasisPoints) + премия за дизайн (designBase ×
///    designRateBasisPoints). salaryBase здесь = чек − доставка − дизайн.
enum EnumAccrualKind {
  EXECUTOR
  MANAGER
}

model SalaryAccrual {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderId String
  order   OrderPhoto @relation(fields: [orderId], references: [id])

  executorId String
  executor   User   @relation(fields: [executorId], references: [id])

  kind EnumAccrualKind @default(EXECUTOR)

  salaryBase      Int
  rateBasisPoints Int
  salaryAmount    Int

  // Только для kind=MANAGER: база и ставка премии за разработку дизайна.
  // Часть salaryAmount = round(designBase × designRateBasisPoints / 10000).
  designBase            Int @default(0)
  designRateBasisPoints Int @default(0)

  status     EnumAccrualStatus @default(PENDING)
  paidAmount Int               @default(0)

  paymentLinks PaymentAccrualLink[]

  @@index([executorId, status])
  @@index([orderId, status])
  @@index([orderId, kind])
}

model SalaryPayment {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  executorId String
  executor   User   @relation("SalaryPaymentExecutor", fields: [executorId], references: [id])

  paidById String
  paidBy   User   @relation("SalaryPaymentAuthor", fields: [paidById], references: [id])

  amount Int
  note   String?

  accrualLinks PaymentAccrualLink[]
}

model PaymentAccrualLink {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  paymentId String
  payment   SalaryPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  accrualId String
  accrual   SalaryAccrual @relation(fields: [accrualId], references: [id])

  amount Int

  @@unique([paymentId, accrualId])
}

model StatusHistory {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  orderId String
  order   OrderPhoto @relation(fields: [orderId], references: [id], onDelete: Cascade)

  fromStatus String?
  toStatus   String
  changedBy  String
}

model OrderAssignment {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  orderId String
  order   OrderPhoto @relation(fields: [orderId], references: [id], onDelete: Cascade)

  executorId String
  assignedBy String
  note       String?
}

model UserRateHistory {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  oldRateBasisPoints Int?
  newRateBasisPoints Int
  changedBy          String
}

model ExpenseOrder {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category EnumExpenseCategory
  amount   Int
  note     String?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  // Расход, привязанный к заказу (например, авто-вознаграждение партнёра).
  // SetNull: удаление заказа не должно стирать историю расходов.
  orderId String?
  order   OrderPhoto? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([orderId, category])
}

/// Настройки расчёта с партнёром-исполнителем (печать футболок).
/// Одна строка на систему; правится администратором. Значения по умолчанию
/// подставляются в новую позицию, но в самой позиции их можно переопределить.
model PartnerSettings {
  id        String   @id @default("default")
  updatedAt DateTime @updatedAt

  thermalTransferCost    Int    @default(70)
  blankTshirtCost        Int    @default(260)
  // Доля партнёра от маржи в сотых процента: 3000 = 30%.
  partnerRateBasisPoints Int    @default(3000)
  partnerName            String @default("Партнёр")
}

/// Задача из планировщика. Ставит администратор, выполняет исполнитель.
/// Напоминания уходят в рабочий чат раз в день, пока задача не закрыта.
model Task {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title       String
  description String?
  status      EnumTaskStatus @default(OPEN)

  /// Срок необязателен: без него задача живёт в списке, но не пингует в чат.
  deadline    DateTime?
  completedAt DateTime?

  assigneeId String
  assignee   User   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Restrict)

  createdById String
  createdBy   User   @relation("TaskAuthor", fields: [createdById], references: [id])

  /// Необязательная привязка к заказу — «переделать макет к 202607-015».
  orderId String?
  order   OrderPhoto? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  /// Дата последнего дайджеста (YYYY-MM-DD по Москве). Защищает от повторной
  /// отправки, если контейнер перезапустился в тот же день.
  lastRemindedOn String?

  @@index([assigneeId, status])
  @@index([status, deadline])
}

enum EnumTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

/// Одна строка на всю систему для флагов планировщиков. Нужна, чтобы
/// ежедневные рассылки (например, план дня) не повторялись при рестарте
/// контейнера: храним дату последней отправки по Москве (YYYY-MM-DD).
model AppState {
  id                  String  @id @default("default")
  updatedAt           DateTime @updatedAt
  dailyPlanLastSentOn String?
}
