generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(uuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  username        String   @unique
  password        String
  role            EnumRole @default(EXECUTOR)
  isActive        Boolean  @default(true)
  rateBasisPoints Int?

  salaryAccruals     SalaryAccrual[]
  salaryPayments     SalaryPayment[]   @relation("SalaryPaymentExecutor")
  authorizedPayments SalaryPayment[]   @relation("SalaryPaymentAuthor")
  assignedOrders     OrderPhoto[]      @relation("OrderExecutor")
  rateHistory        UserRateHistory[]
  expenseOrders      ExpenseOrder[]
}

enum EnumRole {
  ADMIN
  EXECUTOR
}

model OrderPhoto {
  id        String   @id() @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  numberOrder           String              @unique
  sourceOrder           EnumSourceOrder
  communicationPlatform EnumCommunication
  urlCommunication      String
  deliveryMethod        EnumDeliveryMethod
  deliveryCost          Int
  totalOrder            Int
  note                  String?
  status                EnumStatus          @default(NEW)
  productCategory       EnumProductCategory @default(PHOTO)
  deadline              DateTime?
  isUrgent              Boolean             @default(false)
  // Свободная (договорная) цена: сумма позиции = её цене, количество НЕ умножается.
  isFreePrice           Boolean             @default(false)
  // Оставил ли клиент отзыв (отмечается вручную в списке заказов).
  clientReviewLeft      Boolean             @default(false)

  executorId   String?
  executor     User?     @relation("OrderExecutor", fields: [executorId], references: [id])
  completedAt  DateTime?
  clientPaidAt DateTime?

  items          ItemPhoto[]
  tshirtItems    ItemTshirt[]
  accruals       SalaryAccrual[]
  statusHistory  StatusHistory[]
  assignments    OrderAssignment[]
  stockMovements StockMovement[]

  @@index([status])
  @@index([executorId])
  @@index([createdAt])
  @@index([productCategory])
  @@index([status, productCategory])
}

/// Остаток футболок на складе по размеру и цвету (6 размеров × 2 цвета).
model TshirtStock {
  id        String         @id @default(uuid())
  size      EnumTshirtSize
  color     String
  quantity  Int            @default(0)
  updatedAt DateTime       @updatedAt

  @@unique([size, color])
}

/// Журнал списаний склада по заказу (положительное quantity = списано).
/// Возврат при откате из «Отправлен»/удалении возвращает ровно списанное.
model StockMovement {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  orderId String
  order   OrderPhoto @relation(fields: [orderId], references: [id], onDelete: Cascade)

  size     EnumTshirtSize
  color    String
  quantity Int

  @@index([orderId])
}

enum EnumProductCategory {
  PHOTO
  TSHIRT
}

enum EnumSourceOrder {
  AVITO
  OZON
  WB
  LOCAL
}

enum EnumCommunication {
  AVITO
  TELEGRAM
  MAX
  OZON
}

enum EnumStatus {
  LEAD
  NEW
  FOLDER_STRUCTURE_CREATED
  PRINTED
  READY
  DONE
  SENT
  PAID
  READY_FOR_REVIEW
  COMPLETED
  CANCELLED
}

enum EnumDeliveryMethod {
  YANDEX_PVZ
  OZON_PVZ
  PICKUP
  OZON_SELLER
  WB_SELLER
}

model ItemPhoto {
  id        String   @id() @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   OrderPhoto @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  formatPaper   String
  typePaper     EnumTypePaper
  quantity      Int
  price         Int
  pricePosition Int
}

enum EnumTypePaper {
  GLOSS
  MATTE
}

model ItemTshirt {
  id        String   @id() @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   OrderPhoto @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  color         String
  size          EnumTshirtSize
  gender        EnumTshirtGender  @default(UNISEX)
  printLocation EnumPrintLocation
  printType     EnumPrintType     @default(DTF)
  quantity      Int
  price         Int
  pricePosition Int
  designCost    Int               @default(0)
  designUrl     String?
  designNote    String?
}

enum EnumTshirtSize {
  XS
  S
  M
  L
  XL
  XXL
  XXXL
}

enum EnumTshirtGender {
  UNISEX
  MALE
  FEMALE
  KIDS
}

enum EnumPrintLocation {
  FRONT
  BACK
  FRONT_BACK
  SLEEVE_LEFT
  SLEEVE_RIGHT
  FULL
  BY_TZ
}

enum EnumPrintType {
  DTF
  DTG
  SILK
  SUBLIMATION
}

enum EnumAccrualStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  SETTLED
  REVERSED
}

model SalaryAccrual {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderId String
  order   OrderPhoto @relation(fields: [orderId], references: [id])

  executorId String
  executor   User   @relation(fields: [executorId], references: [id])

  salaryBase      Int
  rateBasisPoints Int
  salaryAmount    Int

  status     EnumAccrualStatus @default(PENDING)
  paidAmount Int               @default(0)

  paymentLinks PaymentAccrualLink[]

  @@index([executorId, status])
  @@index([orderId, status])
}

model SalaryPayment {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  executorId String
  executor   User   @relation("SalaryPaymentExecutor", fields: [executorId], references: [id])

  paidById String
  paidBy   User   @relation("SalaryPaymentAuthor", fields: [paidById], references: [id])

  amount Int
  note   String?

  accrualLinks PaymentAccrualLink[]
}

model PaymentAccrualLink {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  paymentId String
  payment   SalaryPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  accrualId String
  accrual   SalaryAccrual @relation(fields: [accrualId], references: [id])

  amount Int

  @@unique([paymentId, accrualId])
}

model StatusHistory {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  orderId String
  order   OrderPhoto @relation(fields: [orderId], references: [id], onDelete: Cascade)

  fromStatus String?
  toStatus   String
  changedBy  String
}

model OrderAssignment {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  orderId String
  order   OrderPhoto @relation(fields: [orderId], references: [id], onDelete: Cascade)

  executorId String
  assignedBy String
  note       String?
}

model UserRateHistory {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  oldRateBasisPoints Int?
  newRateBasisPoints Int
  changedBy          String
}

model ExpenseOrder {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category EnumProductCategory
  amount   Int
  note     String?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])
}
