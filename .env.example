# Скопируй этот файл в .env и заполни
DB_PASSWORD=придумай_сложный_пароль_123
JWT_SECRET=придумай_длинный_секрет_для_токенов_abc

# Telegram-уведомления рабочей группе
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_CHAT_ID=

# ── Интеграция с исполнителем-партнёром (печать футболок) ──────────────────
# См. docs/partner-integration.md. Пока PARTNER_WEBHOOK_URL пуст — кнопка
# «Отправить исполнителю» пометит заказ ошибкой, данные не потеряются.
#
# Куда мы шлём заказ (вебхук партнёра) и наш токен для него:
PARTNER_WEBHOOK_URL=
PARTNER_WEBHOOK_TOKEN=
# Токен, которым партнёр авторизуется у нас (забирает заказ/ТЗ-фото/стикер):
PARTNER_API_TOKEN=
# Публичный адрес нашего API для ссылок на файлы в вебхуке:
PUBLIC_BASE_URL=
# Каталог хранения ТЗ-фото (в контейнере — том /app/uploads):
UPLOAD_DIR=/app/uploads
